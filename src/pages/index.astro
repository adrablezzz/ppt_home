			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				width: 100%;
				height: 100%;
				overflow: hidden;
				background: var(--near-black);
				color: var(--near-black);
				font-family: var(--sans);
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.deck-shell {
				width: 100vw;
				height: 100vh;
				height: 100dvh;
				background:
					linear-gradient(rgba(245, 244, 237, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(245, 244, 237, 0.03) 1px, transparent 1px),
