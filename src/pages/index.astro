			.slide.active .mini-card:nth-child(1),
			.slide.active .list li:nth-child(1),
			.slide.active .flow-step:nth-child(1) {
				animation-delay: 240ms;
			}

			.slide.active .mini-card:nth-child(2),
			.slide.active .list li:nth-child(2),
			.slide.active .flow-step:nth-child(2) {
				animation-delay: 320ms;
			}

			.slide.active .mini-card:nth-child(3),
			.slide.active .list li:nth-child(3),
			.slide.active .flow-step:nth-child(3) {
				animation-delay: 400ms;
			}

			.slide.active .flow-step:nth-child(4) {
				animation-delay: 480ms;
			}

			.slide.active .flow-step:nth-child(5) {
				animation-delay: 560ms;
			}

			.panel {
				padding: 42px;
			}

			.quote-card {
				padding: 58px 64px;
			}

			.quote-card p {
				margin: 0;
				font-family: var(--serif);
				font-size: 72px;
				line-height: 1.16;
				text-wrap: pretty;
			}

			.quote-card small {
				display: block;
				margin-top: 30px;
				color: var(--stone);
				font-size: 24px;
			}

			.mini-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 24px;
			}

			.mini-grid.two {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.mini-card {
				padding: 32px;
				min-height: 200px;
				display: flex;
				flex-direction: column;
				gap: 18px;
			}

			.mini-card strong {
				font-family: var(--serif);
				font-size: 36px;
				line-height: 1.12;
				font-weight: 500;
				color: var(--near-black);
			}

			.mini-card span,
			.mini-card p {
				margin: 0;
				color: var(--olive);
				font-size: 24px;
				line-height: 1.42;
			}

			.slide.dark .mini-card span,
			.slide.dark .mini-card p {
				color: var(--silver);
			}

			.list {
				margin: 0;
				padding: 0;
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 22px;
			}

			.list li {
				padding: 24px 28px;
				border-radius: 16px;
				background: rgba(250, 249, 245, 0.7);
				box-shadow: 0 0 0 1px var(--border-cream);
				color: var(--olive);
				font-size: 28px;
				line-height: 1.34;
			}

			.slide.dark .list li {
				background: rgba(48, 48, 46, 0.8);
				box-shadow: 0 0 0 1px #3d3d3a;
				color: var(--silver);
			}

			.compare {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 28px;
				height: 100%;
			}

			.compare-card {
				border-radius: 24px;
				padding: 48px;
				background: var(--ivory);
				border: 1px solid var(--border-warm);
				display: flex;
				flex-direction: column;
				gap: 28px;
			}

			.compare-card.dark-card {
				background: var(--dark-surface);
				color: var(--ivory);
				border-color: #3d3d3a;
			}

			.compare-card .tag {
				width: fit-content;
				padding: 10px 16px;
				border-radius: 999px;
				background: var(--warm-sand);
				color: var(--charcoal);
				font-size: 20px;
			}

			.compare-card.dark-card .tag {
				background: var(--near-black);
				color: var(--silver);
			}

			.table {
				display: grid;
				border-radius: 20px;
				overflow: hidden;
				border: 1px solid var(--border-warm);
			}

			.row {
				display: grid;
				grid-template-columns: 0.8fr 1fr 1fr;
				min-height: 112px;
			}

			.row + .row {
				border-top: 1px solid var(--border-warm);
			}

			.cell {
				padding: 28px 32px;
				background: var(--ivory);
				font-size: 27px;
				line-height: 1.3;
				color: var(--olive);
			}

			.cell + .cell {
				border-left: 1px solid var(--border-warm);
			}

			.header .cell {
				background: var(--warm-sand);
				color: var(--near-black);
				font-family: var(--serif);
				font-size: 32px;
			}

			.flow {
				display: grid;
				grid-template-columns: repeat(5, minmax(0, 1fr));
				gap: 22px;
				align-items: stretch;
			}

			.flow-step {
				position: relative;
				padding: 30px 26px;
				border-radius: 18px;
				background: var(--ivory);
				box-shadow: 0 0 0 1px var(--border-warm);
				min-height: 190px;
			}

			.flow-step::after {
				content: "";
				position: absolute;
				top: 50%;
				right: -17px;
				width: 12px;
				height: 12px;
				border-top: 2px solid var(--terracotta);
				border-right: 2px solid var(--terracotta);
				transform: translateY(-50%) rotate(45deg);
			}

			.flow-step:last-child::after {
				display: none;
			}

			.flow.vertical .flow-step::after {
				display: none;
			}

			.flow-step b {
				display: block;
				margin-bottom: 18px;
				font-family: var(--serif);
				font-size: 31px;
				font-weight: 500;
			}

			.flow-step span {
				color: var(--olive);
				font-size: 22px;
				line-height: 1.36;
			}

			.image-frame {
				overflow: hidden;
				position: relative;
				transition:
					transform 220ms ease,
					box-shadow 220ms ease;
			}

			.image-frame:hover,
			.image-frame:focus-visible {
				transform: translateY(-4px);
				box-shadow:
					rgba(20, 20, 19, 0.08) 0 12px 34px,
					0 0 0 1px var(--border-warm);
				outline: none;
			}

			.image-frame img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.image-frame.contain img {
				object-fit: contain;
				background: var(--ivory);
			}

			.image-frame.tall img {
				object-position: center top;
			}

			.image-caption {
				position: absolute;
				left: 18px;
				bottom: 18px;
				max-width: calc(100% - 36px);
				padding: 10px 14px;
				border-radius: 14px;
				background: rgba(20, 20, 19, 0.76);
				color: var(--ivory);
				font-size: 18px;
				line-height: 1.35;
				backdrop-filter: blur(10px);
			}

			.prompt-caption {
				font-size: 20px;
				text-wrap: pretty;
			}

			.source-row {
				display: flex;
				flex-wrap: wrap;
				gap: 14px;
				align-items: center;
			}

			.source-link {
				display: inline-flex;
				align-items: center;
				min-height: 46px;
				padding: 10px 16px;
				border-radius: 14px;
				background: rgba(250, 249, 245, 0.72);
				color: var(--olive);
				font-size: 19px;
				line-height: 1.25;
				box-shadow: 0 0 0 1px var(--border-warm);
			}

			.source-link:hover,
			.source-link:focus-visible {
				color: var(--near-black);
				background: var(--warm-sand);
				outline: none;
			}

			.slide.dark .source-link:hover,
			.slide.dark .source-link:focus-visible {
				color: var(--ivory);
				background: #3d3d3a;
			}

			.screenshot-grid {
				display: grid;
				gap: 28px;
			}

			.screenshot-grid.three {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}

			.big-number {
				font-family: var(--serif);
				font-size: 170px;
				line-height: 0.9;
				color: var(--terracotta);
			}

			.code-sample {
				margin: 0;
				padding: 34px 38px;
				border-radius: 18px;
				background: var(--near-black);
				color: var(--silver);
				font-family: var(--mono);
				font-size: 24px;
				line-height: 1.5;
				white-space: pre-wrap;
				box-shadow: 0 0 0 1px var(--dark-surface);
			}

			.deck-controls {
				position: fixed;
				left: 50%;
				bottom: 22px;
				transform: translateX(-50%);
				z-index: 20;
				display: flex;
				align-items: center;
				gap: 12px;
				padding: 10px;
				border-radius: 999px;
				background: rgba(20, 20, 19, 0.76);
				backdrop-filter: blur(16px);
				box-shadow: 0 0 0 1px rgba(245, 244, 237, 0.16);
			}

			.deck-controls button {
				min-width: 44px;
				height: 44px;
				border: 0;
				border-radius: 999px;
				background: var(--warm-sand);
				color: var(--charcoal);
				font-size: 20px;
				cursor: pointer;
				box-shadow: 0 0 0 1px var(--border-warm);
			}

			.deck-controls button:hover,
			.deck-controls button:focus-visible {
				background: var(--ivory);
				outline: none;
			}

			.deck-controls button:disabled {
				opacity: 0.45;
				cursor: not-allowed;
			}

			.counter {
				min-width: 86px;
				text-align: center;
				color: var(--ivory);
				font-family: var(--mono);
				font-size: 15px;
			}

			.progress {
				position: fixed;
				left: 0;
				bottom: 0;
				width: 100%;
				height: 4px;
				background: rgba(245, 244, 237, 0.14);
				z-index: 21;
			}

			.progress span {
				display: block;
				width: 0;
				height: 100%;
				background: var(--terracotta);
				transition: width 240ms ease;
			}

			.paper-orbit {
				position: absolute;
				right: -210px;
				bottom: -250px;
				width: 620px;
				height: 620px;
				border-radius: 50%;
				border: 1px solid var(--border-warm);
				opacity: 0.55;
			}

			.paper-orbit::before {
				content: "";
				position: absolute;
				inset: 92px;
				border-radius: inherit;
				border: 1px solid var(--border-cream);
			}

			@keyframes slideInForward {
				from {
					opacity: 0;
					transform: translateX(36px) scale(0.992);
				}
				to {
					opacity: 1;
					transform: translateX(0) scale(1);
				}
			}

			@keyframes slideInBackward {
				from {
					opacity: 0;
					transform: translateX(-36px) scale(0.992);
				}
				to {
					opacity: 1;
					transform: translateX(0) scale(1);
				}
			}

			@keyframes liftIn {
				from {
					opacity: 0;
					transform: translateY(22px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@media (prefers-reduced-motion: reduce) {
				* {
					scroll-behavior: auto !important;
					transition-duration: 0.01ms !important;
					animation-duration: 0.01ms !important;
				}
			}
		</style>
	</head>
	<body>
		<main class="deck-shell" aria-label="个人 AI 编程经验分享 PPT">
			<div class="stage" id="stage">
				<section class="slide active" data-screen-label="01 封面">
					<div class="paper-orbit"></div>
					<div class="slide-grid center">
						<p class="kicker">Technical Sharing / AI Programming</p>
						<h1>个人 AI 编程经验分享</h1>
						<p class="body" style="max-width: 940px;">
							工具选择、使用流程、踩坑总结，以及一个更重要的结论：AI 编程本质上是文档能力的放大器。
						</p>
					</div>
					<div class="slide-no">01 / 21</div>
				</section>

				<section class="slide dark" data-screen-label="02 核心观点">
					<div class="slide-grid center">
						<p class="kicker">Core thesis</p>
						<div class="quote-card" style="max-width: 1280px;">
							<p>AI 编程的上限，取决于你写文档的能力。</p>
							<small>需求、边界、规则和审查标准，决定 Agent 最终能抵达哪里。</small>
						</div>
					</div>
					<div class="slide-no">02 / 21</div>
				</section>

				<section class="slide" data-screen-label="03 为什么需要 AI 编程">
					<div class="chapter-mark">01</div>
					<div class="slide-grid two-col">
						<div class="stack">
							<p class="kicker">Pain points</p>
							<h2>传统开发里，时间常常不是花在创造上。</h2>
							<p class="body">很多精力被消耗在重复搜索、样板代码和上下文切换中。</p>
						</div>
						<ul class="list">
							<li><strong>查文档 / 搜索引擎：</strong>找 API 用法，排查报错，反复确认边界。</li>
							<li><strong>写样板代码：</strong>CRUD、配置文件、测试用例，机械但不可省。</li>
							<li><strong>上下文切换：</strong>从需求、设计、实现、验证之间频繁跳跃。</li>
						</ul>
					</div>
					<div class="slide-no">03 / 21</div>
				</section>

				<section class="slide" data-screen-label="04 AI 的价值">
